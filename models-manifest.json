  "llama_server_args_profiles": {
    "comment": "llama-server launch args by model family. Each catalog entry sets llama_server_args_profile to select one.",
    "llama": {
      "llama_server_args": [
        "--no-jinja"
      ],
      "notes": "Llama 3.x Jinja template echoes tool-call JSON instead of answering."
    },
    "qwen": {
      "llama_server_args": [
        "--jinja",
        "--reasoning-budget",
        "0"
      ],
      "notes": "Qwen 2.5+ uses Jinja chat template. reasoning-budget 0 suppresses thinking traces on Qwen3-class models; harmless on Qwen 2.5."
    },
    "gemma_2": {
      "llama_server_args": [],
      "notes": "Gemma 2 has no thinking mode; llama-server defaults are fine."
    },
    "gemma_4": {
      "llama_server_args": [
        "--jinja",
        "--reasoning",
        "off",
        "--reasoning-budget",
        "0",
        "--chat-template-kwargs",
        "{\"enable_thinking\":false}",
        "--reasoning-format",
        "deepseek"
      ],
      "llama_chat_template_kwargs": {
        "enable_thinking": false
      },
      "notes": "Gemma 4 thinking must be disabled explicitly; reasoning-budget 0 alone still leaks planning steps."
    }
  },
