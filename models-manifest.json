  "app_selection_logic": {
    "comment": "Suggested auto-selection logic based on detected unified memory. Your app should detect RAM via sysctl hw.memsize on macOS and divide by 1073741824 to get GB.",
    "rules": [
      {
        "condition": "ram_gb == 8",
        "recommended_model": "gemma-4-e4b-q4_k_m",
        "alternatives": ["qwen2.5-7b-q4_k_m", "llama-3.1-8b-q4_k_m"],
        "note": "Gemma 4 E4B is the best fit for 8GB — fast MoE model with excellent quality. Qwen 2.5 7B is a strong alternative. Llama 3.1 8B fits but leaves tight headroom."
      },
      {
        "condition": "ram_gb == 16",
        "recommended_model": "qwen2.5-14b-q4_k_m",
        "alternatives": ["llama-3.1-8b-q4_k_m", "gemma-2-9b-q4_k_m", "gemma-4-e4b-q4_k_m"],
        "note": "Qwen 2.5 14B is the sweet spot for 16GB — noticeably better than 8B models. Llama 3.1 8B and Gemma 2 9B are faster alternatives."
      },
      {
        "condition": "ram_gb >= 24 && ram_gb < 48",
        "recommended_model": "qwen2.5-32b-q4_k_m",
        "alternatives": ["gemma-4-31b-q4_k_m", "llama-3.3-70b-q4_k_m"],
        "note": "Qwen 32B or Gemma 4 31B deliver near-70B quality. Llama 3.3 70B fits on 48GB only."
      },
      {
        "condition": "ram_gb >= 48 && ram_gb < 64",
        "recommended_model": "llama-3.3-70b-q4_k_m",
        "alternatives": ["qwen2.5-72b-q4_k_m", "qwen2.5-32b-q4_k_m"],
        "note": "Llama 3.3 70B and Qwen 2.5 72B both fit. Warn about 40–47 GB download size."
      },
      {
        "condition": "ram_gb >= 64",
        "recommended_model": "qwen2.5-72b-q4_k_m",
        "alternatives": ["llama-3.3-70b-q4_k_m"],
        "note": "Both 70B/72B models run comfortably. Offer user the choice."
      }
    ]
  }
}
